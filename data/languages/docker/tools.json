{
  "Docker": {
    "name": "Docker",
    "description": "Docker is a platform for developing, shipping, and running applications in containers",
    "category": "containerization",
    "website": "https://docker.com",
    "confidence": 95,
    "patterns": {
      "files": ["Dockerfile", "docker-compose.yml", "docker-compose.yaml", ".dockerignore"],
      "dockerfile": ["FROM ", "RUN ", "COPY ", "ADD ", "EXPOSE ", "CMD ", "ENTRYPOINT "],
      "compose": ["version:", "services:", "volumes:", "networks:", "image:", "build:"],
      "scripts": ["docker build", "docker run", "docker push", "docker pull"]
    },
    "versions": {
      "patterns": ["# syntax=docker/dockerfile:([\\d\\.]+)", "version: ['\"]([\\d\\.]+)['\"]"],
      "files": ["Dockerfile", "docker-compose.yml"]
    },
    "implies": ["Containerization"],
    "oss": true
  },
  "Kubernetes": {
    "name": "Kubernetes",
    "description": "Kubernetes is an open-source container orchestration platform",
    "category": "orchestration",
    "website": "https://kubernetes.io",
    "confidence": 95,
    "patterns": {
      "files": ["*.yaml", "*.yml", "kustomization.yaml", "Chart.yaml"],
      "yaml": ["apiVersion:", "kind:", "metadata:", "spec:", "kubectl", "namespace:"],
      "kinds": ["Deployment", "Service", "Pod", "ConfigMap", "Secret", "Ingress"],
      "directories": ["k8s/", "kubernetes/", "manifests/", "charts/"]
    },
    "versions": {
      "patterns": ["apiVersion: apps/v([\\d]+)", "kubernetes.io/([\\d\\.]+)"],
      "files": ["*.yaml", "*.yml"]
    },
    "implies": ["Docker", "Containerization"],
    "oss": true
  },
  "Helm": {
    "name": "Helm",
    "description": "The package manager for Kubernetes",
    "category": "package_manager",
    "website": "https://helm.sh",
    "confidence": 95,
    "patterns": {
      "files": ["Chart.yaml", "values.yaml", "requirements.yaml", "Chart.lock"],
      "yaml": ["apiVersion: v2", "name:", "version:", "description:", "type: application"],
      "directories": ["charts/", "templates/", "helm/"],
      "templates": ["{{ .Values", "{{ .Chart", "{{ .Release", "{{ include"]
    },
    "versions": {
      "patterns": ["apiVersion: v([\\d]+)", "version: ([\\d\\.]+)"],
      "files": ["Chart.yaml"]
    },
    "implies": ["Kubernetes"],
    "oss": true
  },
  "Podman": {
    "name": "Podman",
    "description": "A daemonless container engine for developing, managing, and running OCI Containers",
    "category": "containerization",
    "website": "https://podman.io",
    "confidence": 90,
    "patterns": {
      "files": ["Containerfile", "podman-compose.yml"],
      "scripts": ["podman build", "podman run", "podman push", "podman pull"],
      "config": ["containers.conf", "registries.conf", "storage.conf"]
    },
    "versions": {
      "patterns": ["podman version ([\\d\\.]+)", "podman-([\\d\\.]+)"],
      "files": ["scripts/", "Makefile"]
    },
    "implies": ["Containerization"],
    "oss": true
  }
} 